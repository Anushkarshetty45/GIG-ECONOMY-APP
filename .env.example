# =============================================================================
# ENVIRONMENT VARIABLES TEMPLATE
# =============================================================================
# Copy this file to .env and replace all placeholder values with your actual credentials
# NEVER commit the .env file to version control!
#
# Setup Instructions:
# 1. Copy this file: cp .env.example .env
# 2. Get your credentials from respective services
# 3. Replace all YOUR_* placeholders with actual values
# =============================================================================

# Supabase Configuration
# Get these from: https://app.supabase.com/project/_/settings/api
# IMPORTANT: Must start with VITE_ prefix for Vite to expose them
VITE_SUPABASE_URL=YOUR_SUPABASE_PROJECT_URL
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Plaid Configuration (Bank Linking) - OPTIONAL
# Get these from: https://dashboard.plaid.com/team/keys
# WARNING: These are sensitive credentials!
VITE_PLAID_CLIENT_ID=YOUR_PLAID_CLIENT_ID
VITE_PLAID_SECRET=YOUR_PLAID_SECRET
VITE_PLAID_ENV=sandbox

# Stripe Configuration (Payments) - OPTIONAL
# Get these from: https://dashboard.stripe.com/apikeys
# CRITICAL: Secret key should NEVER be used in frontend code!
VITE_STRIPE_PUBLISHABLE_KEY=YOUR_STRIPE_PUBLISHABLE_KEY
# WARNING: Server-side only! Do not use in React components
STRIPE_SECRET_KEY=YOUR_STRIPE_SECRET_KEY
